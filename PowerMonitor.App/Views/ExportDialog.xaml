<Window x:Class="PowerMonitor.App.Views.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="导出数据" Height="220" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A1A2E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="选择导出时间范围" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="开始日期" Foreground="#CCC" FontSize="12" Margin="0,0,0,3"/>
            <DatePicker x:Name="StartPicker" SelectedDate="{x:Static system:DateTime.Today}"
                        xmlns:system="clr-namespace:System;assembly=mscorlib"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="结束日期" Foreground="#CCC" FontSize="12" Margin="0,0,0,3"/>
            <DatePicker x:Name="EndPicker" SelectedDate="{x:Static system:DateTime.Today}"
                        xmlns:system="clr-namespace:System;assembly=mscorlib"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Click="Cancel_Click" Width="70"
                    Background="#333" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
            <Button Content="导出" Click="Export_Click" Width="70"
                    Background="#00C864" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
