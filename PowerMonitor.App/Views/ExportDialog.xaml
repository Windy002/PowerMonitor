<Window x:Class="PowerMonitor.App.Views.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" Background="#0C0C0C"
        Height="280" Width="380" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="TitleBar_MouseDown">
    <Border BorderBrush="#20FFFFFF" BorderThickness="0.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Padding="14,0" BorderBrush="#15FFFFFF" BorderThickness="0,0,0,0.5"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="导出数据" Foreground="#E0E0E0" FontSize="12"
                               FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" Click="Cancel_Click" HorizontalAlignment="Right"
                            Width="30" Height="26" FontSize="10" Foreground="#888">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="4" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="开始日期" Foreground="#888" FontSize="12"
                               FontFamily="Microsoft YaHei UI" Margin="0,0,0,4"/>
                    <DatePicker x:Name="StartPicker" FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,14">
                    <TextBlock Text="结束日期" Foreground="#888" FontSize="12"
                               FontFamily="Microsoft YaHei UI" Margin="0,0,0,4"/>
                    <DatePicker x:Name="EndPicker" FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">
                    <Button Content="取消" Click="Cancel_Click" Width="72" Height="30"
                            FontSize="12" FontFamily="Microsoft YaHei UI" Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="6" Background="#15FFFFFF"
                                        BorderBrush="#25FFFFFF" BorderThickness="0.5">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="导出" Click="Export_Click" Width="72" Height="30"
                            FontSize="12" FontFamily="Microsoft YaHei UI"
                            Foreground="#0C0C0C">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="6" Background="#60CD89">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
