<UserControl x:Class="PowerMonitor.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#0C0C0C">
        <StackPanel MaxWidth="440" Margin="32,24">
            <TextBlock Text="设置" Foreground="#E0E0E0" FontSize="22" FontWeight="SemiBold"
                       FontFamily="Microsoft YaHei UI" Margin="0,0,0,24"/>

            <Border CornerRadius="10" Padding="24,20" Margin="0,0,0,16"
                    BorderBrush="#18FFFFFF" BorderThickness="0.5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#12FFFFFF" Offset="0"/>
                        <GradientStop Color="#06FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="电价 (¥/kWh)" Foreground="#AAA" FontSize="13"
                               FontFamily="Microsoft YaHei UI" Margin="0,0,0,6"/>
                    <Border CornerRadius="6" Background="#12FFFFFF"
                            BorderBrush="#20FFFFFF" BorderThickness="0.5" Padding="2">
                        <TextBox Text="{Binding PricePerKwh}" BorderThickness="0"
                                 Background="Transparent" Foreground="#E0E0E0"
                                 FontSize="15" Padding="8,6" FontFamily="Segoe UI"/>
                    </Border>

                    <TextBlock Text="采样间隔 (1-60 秒)" Foreground="#AAA" FontSize="13"
                               FontFamily="Microsoft YaHei UI" Margin="0,16,0,6"/>
                    <Border CornerRadius="6" Background="#12FFFFFF"
                            BorderBrush="#20FFFFFF" BorderThickness="0.5" Padding="2">
                        <TextBox Text="{Binding Interval}" BorderThickness="0"
                                 Background="Transparent" Foreground="#E0E0E0"
                                 FontSize="15" Padding="8,6" FontFamily="Segoe UI"/>
                    </Border>

                    <TextBlock Text="数据保留天数" Foreground="#AAA" FontSize="13"
                               FontFamily="Microsoft YaHei UI" Margin="0,16,0,6"/>
                    <Border CornerRadius="6" Background="#12FFFFFF"
                            BorderBrush="#20FFFFFF" BorderThickness="0.5" Padding="2">
                        <TextBox Text="{Binding RetentionDays}" BorderThickness="0"
                                 Background="Transparent" Foreground="#E0E0E0"
                                 FontSize="15" Padding="8,6" FontFamily="Segoe UI"/>
                    </Border>

                    <Button Content="保存设置" Command="{Binding SaveCommand}" Margin="0,16,0,0"
                            Width="100" Height="32" FontSize="13" FontFamily="Microsoft YaHei UI">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="6" Background="#60CD89"
                                        BorderBrush="Transparent" BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="#60CD89"
                               FontSize="13" FontFamily="Microsoft YaHei UI" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Button Content="关于 PowerMonitor..." Click="About_Click" HorizontalAlignment="Left"
                    Height="28" FontSize="12" FontFamily="Microsoft YaHei UI"
                    Foreground="#666">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
