<Window x:Class="PowerMonitor.App.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" Background="#0C0C0C"
        Height="340" Width="400" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="TitleBar_MouseDown">
    <Border BorderBrush="#20FFFFFF" BorderThickness="0.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Padding="14,0" BorderBrush="#15FFFFFF" BorderThickness="0,0,0,0.5"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="关于" Foreground="#E0E0E0" FontSize="12"
                               FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" Click="Close_Click" HorizontalAlignment="Right"
                            Width="30" Height="26" FontSize="10" Foreground="#888">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="4" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="32,24">
                <Border Width="56" Height="56" CornerRadius="28" Background="#60CD8920"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="⚡" FontSize="24" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="PowerMonitor" Foreground="#E0E0E0"
                           FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"
                           FontFamily="Microsoft YaHei UI" Margin="0,0,0,4"/>
                <TextBlock Text="主机功耗监控" Foreground="#888"
                           FontSize="13" HorizontalAlignment="Center"
                           FontFamily="Microsoft YaHei UI" Margin="0,0,0,16"/>

                <Separator Background="#20FFFFFF" Margin="0,0,0,16"/>

                <TextBlock Text="版本 1.1.0" Foreground="#CCC"
                           FontSize="13" HorizontalAlignment="Center"
                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                <TextBlock Text=".NET 8 + WPF + HandyControl" Foreground="#666"
                           FontSize="12" HorizontalAlignment="Center"
                           FontFamily="Segoe UI" Margin="0,0,0,12"/>

                <TextBlock HorizontalAlignment="Center">
                    <Hyperlink NavigateUri="https://github.com/Windy002/PowerMonitor"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="#60CD89" FontSize="12"
                               TextDecorations="None">github.com/Windy002/PowerMonitor</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</Window>
