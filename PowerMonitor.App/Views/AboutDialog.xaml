<Window x:Class="PowerMonitor.App.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A1A2E">
    <Grid Margin="25">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="⚡ PowerMonitor" Foreground="White" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="主机功耗监控" Foreground="#888" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="版本 1.0.0" Foreground="#CCC" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text=".NET 8 + WPF" Foreground="#888" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="技术栈" Foreground="White" FontSize="14" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="LibreHardwareMonitor · OxyPlot · SQLite"
                       Foreground="#AAA" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="数据纯本地存储，不上传任何信息"
                       Foreground="#888" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock HorizontalAlignment="Center">
                <Hyperlink NavigateUri="https://github.com/Windy002/PowerMonitor" RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="#00C864">github.com/Windy002/PowerMonitor</Hyperlink>
            </TextBlock>

            <Button Content="确定" Click="Close_Click" Width="80"
                    Background="#333" Foreground="White" BorderThickness="0"
                    HorizontalAlignment="Center" Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Window>
