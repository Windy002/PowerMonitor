<UserControl x:Class="PowerMonitor.App.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#0C0C0C">
        <Grid Margin="32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding Title}" Foreground="#E0E0E0"
                       FontSize="22" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"
                       Margin="0,0,0,16"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="今日" Click="Day_Click" Width="64" Height="28"
                        FontSize="12" FontFamily="Microsoft YaHei UI" Margin="0,0,4,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="6" Background="#20FFFFFF"
                                    BorderBrush="#30FFFFFF" BorderThickness="0.5">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="本周" Click="Week_Click" Width="64" Height="28"
                        FontSize="12" FontFamily="Microsoft YaHei UI" Margin="0,0,4,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="6" Background="#15FFFFFF"
                                    BorderBrush="#25FFFFFF" BorderThickness="0.5">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="本月" Click="Month_Click" Width="64" Height="28"
                        FontSize="12" FontFamily="Microsoft YaHei UI">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="6" Background="#15FFFFFF"
                                    BorderBrush="#25FFFFFF" BorderThickness="0.5">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <Border Grid.Row="2" CornerRadius="10" Padding="4"
                    BorderBrush="#18FFFFFF" BorderThickness="0.5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#10FFFFFF" Offset="0"/>
                        <GradientStop Color="#04FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <ListView ItemsSource="{Binding Rows}" Background="Transparent"
                          BorderThickness="0" Foreground="#CCC"
                          FontFamily="Segoe UI" FontSize="12">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="时间" DisplayMemberBinding="{Binding Time}" Width="110"/>
                            <GridViewColumn Header="平均" DisplayMemberBinding="{Binding AvgWatts}" Width="65"/>
                            <GridViewColumn Header="最低" DisplayMemberBinding="{Binding MinWatts}" Width="65"/>
                            <GridViewColumn Header="最高" DisplayMemberBinding="{Binding MaxWatts}" Width="65"/>
                            <GridViewColumn Header="耗电" DisplayMemberBinding="{Binding Kwh}" Width="80"/>
                            <GridViewColumn Header="费用" DisplayMemberBinding="{Binding Cost}" Width="70"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Grid>
    </Grid>
</UserControl>
