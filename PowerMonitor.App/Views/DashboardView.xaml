<UserControl x:Class="PowerMonitor.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">
    <Grid Background="#0C0C0C">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top: Hero gauge + chart -->
        <Border Grid.Row="0" Margin="16,16,16,0" Padding="24,20" CornerRadius="12"
                BorderBrush="#20FFFFFF" BorderThickness="0.5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#16FFFFFF" Offset="0"/>
                    <GradientStop Color="#08FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Hero power display -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,40,0">
                    <TextBlock Text="当前功率" Foreground="#888" FontSize="13"
                               FontFamily="Microsoft YaHei UI" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding TotalWatts, StringFormat='{}{0:F0}'}"
                                   Foreground="#60CD89" FontSize="56" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Text="W" Foreground="#60CD8966" FontSize="24"
                                   FontFamily="Segoe UI" VerticalAlignment="Bottom" Margin="4,0,0,10"/>
                    </StackPanel>
                    <!-- Status pill -->
                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left"
                            Margin="0,6,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StateText}" Value="运行中 🟢">
                                        <Setter Property="Background" Value="#15603C"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StateText}" Value="已暂停 🟡">
                                        <Setter Property="Background" Value="#332B00"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StateText}" Foreground="#CCC" FontSize="11"
                                   FontFamily="Microsoft YaHei UI"/>
                    </Border>
                </StackPanel>

                <!-- Chart -->
                <Border Grid.Column="1" CornerRadius="8" ClipToBounds="True">
                    <oxy:PlotView Model="{Binding PlotModel}" Background="Transparent"/>
                </Border>
            </Grid>
        </Border>

        <!-- Bottom: Billing cards + components -->
        <Grid Grid.Row="1" Margin="16,12,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Billing cards -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 今日 -->
                <Border Grid.Row="0" Margin="0,0,0,6" CornerRadius="10" Padding="18,14"
                        BorderBrush="#18FFFFFF" BorderThickness="0.5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#12FFFFFF" Offset="0"/>
                            <GradientStop Color="#06FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="今日电费" Foreground="#888" FontSize="12"
                                   FontFamily="Microsoft YaHei UI"/>
                        <TextBlock Text="{Binding DayCost}" Foreground="#60CD89"
                                   FontSize="32" FontWeight="SemiBold" FontFamily="Segoe UI"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 本周 -->
                <Border Grid.Row="1" Margin="0,3,0,3" CornerRadius="10" Padding="18,14"
                        BorderBrush="#18FFFFFF" BorderThickness="0.5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#10FFFFFF" Offset="0"/>
                            <GradientStop Color="#04FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="本周电费" Foreground="#888" FontSize="12"
                                   FontFamily="Microsoft YaHei UI"/>
                        <TextBlock Text="{Binding WeekCost}" Foreground="#E0E0E0"
                                   FontSize="28" FontWeight="SemiBold" FontFamily="Segoe UI"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 本月 -->
                <Border Grid.Row="2" Margin="0,6,0,0" CornerRadius="10" Padding="18,14"
                        BorderBrush="#18FFFFFF" BorderThickness="0.5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#10FFFFFF" Offset="0"/>
                            <GradientStop Color="#04FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="本月电费" Foreground="#888" FontSize="12"
                                   FontFamily="Microsoft YaHei UI"/>
                        <TextBlock Text="{Binding MonthCost}" Foreground="#E0E0E0"
                                   FontSize="28" FontWeight="SemiBold" FontFamily="Segoe UI"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Right: Component list -->
            <Border Grid.Column="1" Margin="12,0,0,0" CornerRadius="10" Padding="20,16"
                    BorderBrush="#18FFFFFF" BorderThickness="0.5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#10FFFFFF" Offset="0"/>
                        <GradientStop Color="#04FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="硬件功耗" Foreground="#E0E0E0" FontSize="15"
                                   FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                        <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="#60CD89" Margin="0,0,4,0"/>
                            <TextBlock Text="传感器" Foreground="#666" FontSize="10" Margin="0,0,10,0"/>
                            <Ellipse Width="6" Height="6" Fill="#E8A840" Margin="0,0,4,0"/>
                            <TextBlock Text="估算" Foreground="#666" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Components}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Source}" Value="Sensor">
                                                            <Setter Property="Fill" Value="#60CD89"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Source}" Value="Estimated">
                                                            <Setter Property="Fill" Value="#E8A840"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding Name}" Foreground="#AAA" FontSize="13"
                                                   FontFamily="Microsoft YaHei UI"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Watts, StringFormat='{}{0:F1} W'}"
                                               Foreground="#CCC" FontSize="13" FontFamily="Segoe UI"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Bottom info bar -->
                    <Border Grid.Row="2" Margin="0,12,0,0" Padding="0,8,0,0"
                            BorderBrush="#15FFFFFF" BorderThickness="0,0.5,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="{Binding PauseButtonText}" Click="TogglePause_Click"
                                        Width="72" Height="28" FontSize="12"
                                        FontFamily="Microsoft YaHei UI" Margin="0,0,8,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="6" Background="#20FFFFFF"
                                                    BorderBrush="#30FFFFFF" BorderThickness="0.5">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="导出" Click="ExportCsv_Click"
                                        Width="56" Height="28" FontSize="12"
                                        FontFamily="Microsoft YaHei UI">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="6" Background="#15FFFFFF"
                                                    BorderBrush="#25FFFFFF" BorderThickness="0.5">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding PriceInfo}" Foreground="#555" FontSize="11"
                                           FontFamily="Segoe UI" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding IntervalInfo}" Foreground="#555" FontSize="11"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
