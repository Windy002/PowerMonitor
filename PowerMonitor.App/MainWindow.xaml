<Window x:Class="PowerMonitor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        Background="#0C0C0C"
        Height="620" Width="920"
        MinHeight="420" MinWidth="620"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged"
        MouseLeftButtonDown="TitleBar_MouseDown">
    <Border Background="#0C0C0C" BorderBrush="#20FFFFFF" BorderThickness="0.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0" Padding="16,0" BorderBrush="#15FFFFFF" BorderThickness="0,0,0,0.5"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚡" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="PowerMonitor" Foreground="#E0E0E0" FontSize="13"
                                   FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="─" Click="Minimize_Click" Width="34" Height="28"
                                FontSize="12" Foreground="#888">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="4" Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="✕" Click="Close_Click" Width="34" Height="28"
                                FontSize="11" Foreground="#888" Margin="4,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="4" Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Navigation tabs -->
            <Border Grid.Row="1" Background="Transparent" Padding="16,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="DashBtn" Content="仪表盘" Click="Tab_Click" Tag="0"
                                Width="80" Height="32" FontSize="12" FontFamily="Microsoft YaHei UI"
                                Foreground="#E0E0E0"
                                Margin="0,0,4,0" Background="#20FFFFFF">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="8"
                                            Background="{TemplateBinding Background}" BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="HistBtn" Content="历史" Click="Tab_Click" Tag="1"
                                Width="64" Height="32" FontSize="12" FontFamily="Microsoft YaHei UI"
                                Margin="0,0,4,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="8" x:Name="bg"
                                            Background="Transparent" BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="SetBtn" Content="设置" Click="Tab_Click" Tag="2"
                                Width="64" Height="32" FontSize="12" FontFamily="Microsoft YaHei UI">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="8" x:Name="bg"
                                            Background="Transparent" BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <Frame Grid.Row="1" x:Name="DashboardFrame"
                           NavigationUIVisibility="Hidden" Margin="-16,0"/>
                    <Frame Grid.Row="1" x:Name="HistoryFrame"
                           NavigationUIVisibility="Hidden" Visibility="Collapsed" Margin="-16,0"/>
                    <Frame Grid.Row="1" x:Name="SettingsFrame"
                           NavigationUIVisibility="Hidden" Visibility="Collapsed" Margin="-16,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
